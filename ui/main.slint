// Iron Renamer — forge-industrial theme.
// Deep steel darks, molten amber accent, monospace filenames, live preview.

import { ListView, TextEdit } from "std-widgets.slint";

export struct FileRow {
    index: int,
    old_name: string,
    new_name: string,
    dir: string,
    status: string,
    state: int, // 0 unchanged, 1 changed, 2 error
}

export struct RuleRow {
    kind: string,
    summary: string,
}

global Palette {
    out property <color> bg: #0f1114;
    out property <color> panel: #16191e;
    out property <color> inset: #0b0d10;
    out property <color> line: #262b33;
    out property <color> line-soft: #1d2127;
    out property <color> text: #e8e4db;
    out property <color> dim: #7d8593;
    out property <color> faint: #4a515c;
    out property <color> amber: #ffa028;
    out property <color> ember: #ff5c38;
    out property <color> error: #ff6259;
    out property <brush> forge: @linear-gradient(135deg, #ffa028 0%, #ff5c38 100%);
}

component Field inherits Rectangle {
    in property <string> placeholder;
    in-out property <string> text <=> ti.text;
    in property <bool> mono: false;
    callback edited();
    height: 30px;
    background: Palette.inset;
    border-radius: 5px;
    border-width: 1px;
    border-color: ti.has-focus ? Palette.amber : Palette.line;
    animate border-color { duration: 120ms; }
    ti := TextInput {
        x: 10px;
        width: parent.width - 20px;
        height: 100%;
        vertical-alignment: center;
        color: Palette.text;
        font-size: 12px;
        font-family: root.mono ? "Cascadia Mono" : "Segoe UI";
        selection-background-color: #ffa02855;
        edited => { root.edited(); }
    }
    if ti.text == "" && !ti.has-focus : Text {
        x: 10px;
        height: 100%;
        text: root.placeholder;
        color: Palette.faint;
        font-size: 12px;
        vertical-alignment: center;
    }
}

component Chip inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked();
    height: 26px;
    border-radius: 13px;
    background: active ? #ffa02820 : (ta.has-hover ? Palette.line-soft : transparent);
    border-width: 1px;
    border-color: active ? Palette.amber : Palette.line;
    animate background, border-color { duration: 120ms; }
    Text {
        text: root.label;
        color: root.active ? Palette.amber : Palette.dim;
        font-size: 11px;
        font-weight: root.active ? 700 : 400;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component ToolButton inherits Rectangle {
    in property <string> label;
    in property <bool> danger: false;
    callback clicked();
    height: 30px;
    border-radius: 5px;
    background: ta.has-hover ? (danger ? #ff625915 : Palette.line-soft) : transparent;
    border-width: 1px;
    border-color: ta.has-hover ? (danger ? #ff625966 : Palette.line) : Palette.line-soft;
    animate background, border-color { duration: 120ms; }
    Text {
        text: root.label;
        color: root.danger ? Palette.error : Palette.text;
        font-size: 12px;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component MiniButton inherits Rectangle {
    in property <string> glyph;
    in property <bool> danger: false;
    callback clicked();
    width: 22px;
    height: 22px;
    border-radius: 4px;
    background: ta.has-hover ? (danger ? #ff625922 : Palette.line) : transparent;
    Text {
        text: root.glyph;
        color: ta.has-hover ? (root.danger ? Palette.error : Palette.text) : Palette.dim;
        font-size: 11px;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component SectionTitle inherits Text {
    color: Palette.faint;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.6px;
}

export component MainWindow inherits Window {
    title: "Iron Renamer";
    background: Palette.bg;
    preferred-width: 1180px;
    preferred-height: 740px;
    min-width: 900px;
    min-height: 560px;
    default-font-family: "Segoe UI";

    in property <[FileRow]> files: [];
    in property <[RuleRow]> rules: [];
    in property <int> total: 0;
    in property <int> changed: 0;
    in property <int> errors: 0;
    in property <string> status_text: "add files, stack rules, forge names.";
    in property <bool> can_undo: false;

    in-out property <string> new_kind: "replace";
    in-out property <string> field_a: "";
    in-out property <string> field_b: "";
    in-out property <string> case_mode: "lower";
    in-out property <string> apply_part: "both";
    in-out property <bool> replace_ci: false;
    in-out property <string> replace_occ: "all";
    in-out property <string> trim_at: "both";
    in-out property <bool> trim_inv: false;
    in-out property <string> start_text: "1";
    in-out property <string> pad_text: "";

    callback pick_files();
    callback pick_folder();
    callback pick_dirs();
    callback clear_files();
    callback add_rule();
    callback remove_rule(int);
    callback move_rule(int, int);
    callback apply_batch();
    callback undo_batch();
    callback numbering_changed();
    callback insert_tag(string);
    callback row_clicked(int);
    callback save_list();
    callback load_list();
    callback remove_selected();
    callback move_selected(int);
    callback set_override();
    callback sort_changed();
    callback search_changed();
    in-out property <bool> show_tags: false;
    in-out property <int> selected_row: -1;
    in-out property <string> search_text: "";
    in-out property <string> mask_text: "";
    in-out property <bool> recurse: false;
    in-out property <string> sort_by: "manual";
    in-out property <bool> sort_desc: false;
    in-out property <string> override_text: "";
    in-out property <string> batch_mode: "rename";
    in-out property <string> dest_text: "";
    in-out property <string> collide: "fail";
    in-out property <string> collide_pattern: "";
    callback output_changed();

    VerticalLayout {
        padding: 0;
        spacing: 0;

        // ───────────────────────── header
        Rectangle {
            height: 62px;
            background: Palette.panel;
            Rectangle { y: parent.height - 1px; height: 1px; background: Palette.line-soft; }
            HorizontalLayout {
                padding-left: 18px;
                padding-right: 18px;
                spacing: 14px;
                Rectangle {
                    width: 34px;
                    height: 34px;
                    y: (parent.height - self.height) / 2;
                    border-radius: 8px;
                    background: Palette.forge;
                    drop-shadow-blur: 18px;
                    drop-shadow-color: #ff5c3855;
                    Text {
                        text: "IR";
                        color: #17110b;
                        font-size: 15px;
                        font-weight: 900;
                        width: 100%;
                        height: 100%;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    spacing: 1px;
                    Text {
                        text: "IRON RENAMER";
                        color: Palette.text;
                        font-size: 15px;
                        font-weight: 800;
                        letter-spacing: 3px;
                    }
                    Text {
                        text: "batch rename · live preview";
                        color: Palette.faint;
                        font-size: 10px;
                        letter-spacing: 1px;
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: root.total == 0 ? "no files loaded"
                            : root.changed + " of " + root.total + " will change"
                              + (root.errors > 0 ? "  ·  " + root.errors + " conflicts" : "");
                        color: root.errors > 0 ? Palette.error : Palette.dim;
                        font-size: 12px;
                        font-family: "Cascadia Mono";
                    }
                }
            }
        }

        HorizontalLayout {
            padding: 0;
            spacing: 0;

            // ───────────────────────── left rail: rules
            Rectangle {
                width: 296px;
                background: Palette.panel;
                Rectangle { x: parent.width - 1px; width: 1px; background: Palette.line-soft; }

                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;

                    SectionTitle { text: "NEW RULE"; }

                    VerticalLayout {
                        spacing: 6px;
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "Replace"; active: root.new_kind == "replace"; clicked => { root.new_kind = "replace"; } }
                            Chip { label: "Regex";   active: root.new_kind == "regex";   clicked => { root.new_kind = "regex"; } }
                            Chip { label: "Case";    active: root.new_kind == "case";    clicked => { root.new_kind = "case"; } }
                            Chip { label: "Pattern"; active: root.new_kind == "pattern"; clicked => { root.new_kind = "pattern"; } }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "Insert";   active: root.new_kind == "insert";   clicked => { root.new_kind = "insert"; } }
                            Chip { label: "Remove";   active: root.new_kind == "remove";   clicked => { root.new_kind = "remove"; } }
                            Chip { label: "Trim";     active: root.new_kind == "trim";     clicked => { root.new_kind = "trim"; } }
                            Chip { label: "Renumber"; active: root.new_kind == "renumber"; clicked => { root.new_kind = "renumber"; } }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "Move";  active: root.new_kind == "move";  clicked => { root.new_kind = "move"; } }
                            Chip { label: "Swap";  active: root.new_kind == "swap";  clicked => { root.new_kind = "swap"; } }
                            Chip { label: "Names"; active: root.new_kind == "names"; clicked => { root.new_kind = "names"; } }
                        }
                    }

                    if root.new_kind == "replace" || root.new_kind == "regex" : VerticalLayout {
                        spacing: 8px;
                        Field {
                            placeholder: root.new_kind == "replace" ? "find text" : "regex pattern";
                            mono: true;
                            text <=> root.field_a;
                        }
                        Field {
                            placeholder: root.new_kind == "replace" ? "replace with (tags ok)" : "replacement ($1, $2…)";
                            mono: true;
                            text <=> root.field_b;
                        }
                    }

                    if root.new_kind == "replace" : HorizontalLayout {
                        spacing: 6px;
                        Chip { label: "Aa";    active: root.replace_ci;           clicked => { root.replace_ci = !root.replace_ci; } }
                        Chip { label: "all";   active: root.replace_occ == "all";   clicked => { root.replace_occ = "all"; } }
                        Chip { label: "first"; active: root.replace_occ == "first"; clicked => { root.replace_occ = "first"; } }
                        Chip { label: "last";  active: root.replace_occ == "last";  clicked => { root.replace_occ = "last"; } }
                    }

                    if root.new_kind == "case" : VerticalLayout {
                        spacing: 6px;
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "lower";  active: root.case_mode == "lower"; clicked => { root.case_mode = "lower"; } }
                            Chip { label: "UPPER";  active: root.case_mode == "upper"; clicked => { root.case_mode = "upper"; } }
                            Chip { label: "Title";  active: root.case_mode == "title"; clicked => { root.case_mode = "title"; } }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "First";  active: root.case_mode == "first";  clicked => { root.case_mode = "first"; } }
                            Chip { label: "iNVERT"; active: root.case_mode == "invert"; clicked => { root.case_mode = "invert"; } }
                        }
                        Field {
                            placeholder: "scope: at:2,3 · re:PAT · text (blank = all)";
                            mono: true;
                            text <=> root.field_b;
                        }
                    }

                    if root.new_kind == "pattern" : VerticalLayout {
                        spacing: 6px;
                        Field {
                            placeholder: "e.g. trip_<num>.<ext>";
                            mono: true;
                            text <=> root.field_a;
                        }
                        Text {
                            text: "<name> <ext> <num> <index> <parent>";
                            color: Palette.faint;
                            font-size: 10px;
                            font-family: "Cascadia Mono";
                        }
                    }

                    if root.new_kind == "insert" || root.new_kind == "move" : VerticalLayout {
                        spacing: 6px;
                        Field {
                            placeholder: root.new_kind == "insert" ? "text to insert (tags ok)" : "text to move (re:PAT for regex)";
                            mono: true;
                            text <=> root.field_a;
                        }
                        Field {
                            placeholder: "position (blank = end)";
                            mono: true;
                            text <=> root.field_b;
                        }
                        Text {
                            text: "start · end · 2 · -1 · before:txt · after:txt\nrbefore:PAT · rafter:PAT";
                            color: Palette.faint;
                            font-size: 10px;
                            font-family: "Cascadia Mono";
                        }
                    }

                    if root.new_kind == "remove" : VerticalLayout {
                        spacing: 6px;
                        Field {
                            placeholder: "what to remove";
                            mono: true;
                            text <=> root.field_a;
                        }
                        Text {
                            text: "text · re:PAT · pos:2,3 · chars:_-\ndigits · upper · lower · diacritics";
                            color: Palette.faint;
                            font-size: 10px;
                            font-family: "Cascadia Mono";
                        }
                    }

                    if root.new_kind == "trim" : VerticalLayout {
                        spacing: 6px;
                        Field {
                            placeholder: "characters (blank = whitespace)";
                            mono: true;
                            text <=> root.field_a;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "start"; active: root.trim_at == "start"; clicked => { root.trim_at = "start"; } }
                            Chip { label: "end";   active: root.trim_at == "end";   clicked => { root.trim_at = "end"; } }
                            Chip { label: "both";  active: root.trim_at == "both";  clicked => { root.trim_at = "both"; } }
                            Chip { label: "all";   active: root.trim_at == "all";   clicked => { root.trim_at = "all"; } }
                            Chip { label: "inv";   active: root.trim_inv;           clicked => { root.trim_inv = !root.trim_inv; } }
                        }
                    }

                    if root.new_kind == "renumber" : VerticalLayout {
                        spacing: 6px;
                        Field {
                            placeholder: "which number (1 = first)";
                            mono: true;
                            text <=> root.field_a;
                        }
                        Field {
                            placeholder: "+5 · -3 · 10 · 10/2 (start/step)";
                            mono: true;
                            text <=> root.field_b;
                        }
                    }

                    if root.new_kind == "swap" : Field {
                        placeholder: "separator, e.g. \" - \"";
                        mono: true;
                        text <=> root.field_a;
                    }

                    if root.new_kind == "names" : VerticalLayout {
                        spacing: 6px;
                        TextEdit {
                            height: 90px;
                            font-size: 12px;
                            text <=> root.field_a;
                        }
                        Text {
                            text: "one new name per line, in list order";
                            color: Palette.faint;
                            font-size: 10px;
                            font-family: "Cascadia Mono";
                        }
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        Text {
                            text: "apply to";
                            color: Palette.faint;
                            font-size: 10px;
                            vertical-alignment: center;
                        }
                        Chip { label: "name+ext"; active: root.apply_part == "both"; clicked => { root.apply_part = "both"; } }
                        Chip { label: "name";     active: root.apply_part == "name"; clicked => { root.apply_part = "name"; } }
                        Chip { label: "ext";      active: root.apply_part == "ext";  clicked => { root.apply_part = "ext"; } }
                    }

                    Rectangle {
                        height: 32px;
                        border-radius: 5px;
                        background: add-ta.has-hover ? #ffa02830 : #ffa02818;
                        border-width: 1px;
                        border-color: #ffa02866;
                        animate background { duration: 120ms; }
                        Text {
                            text: "+ ADD RULE";
                            color: Palette.amber;
                            font-size: 11px;
                            font-weight: 800;
                            letter-spacing: 1.4px;
                            width: 100%;
                            height: 100%;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        add-ta := TouchArea { clicked => { root.add_rule(); } }
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        SectionTitle { text: "TAGS"; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Chip {
                            label: root.show_tags ? "hide" : "show";
                            active: root.show_tags;
                            clicked => { root.show_tags = !root.show_tags; }
                        }
                    }

                    if root.show_tags : VerticalLayout {
                        spacing: 4px;
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<name>";  clicked => { root.insert_tag("<name>"); } }
                            Chip { label: "<ext>";   clicked => { root.insert_tag("<ext>"); } }
                            Chip { label: "<num>";   clicked => { root.insert_tag("<num>"); } }
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<oname>"; clicked => { root.insert_tag("<oname>"); } }
                            Chip { label: "<oext>";  clicked => { root.insert_tag("<oext>"); } }
                            Chip { label: "<index>"; clicked => { root.insert_tag("<index>"); } }
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<parent>"; clicked => { root.insert_tag("<parent>"); } }
                            Chip { label: "<path>";   clicked => { root.insert_tag("<path>"); } }
                            Chip { label: "<dirnum>"; clicked => { root.insert_tag("<dirnum>"); } }
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<alpha>"; clicked => { root.insert_tag("<alpha>"); } }
                            Chip { label: "<hex>";   clicked => { root.insert_tag("<hex>"); } }
                            Chip { label: "<roman>"; clicked => { root.insert_tag("<roman>"); } }
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<size>";  clicked => { root.insert_tag("<size>"); } }
                            Chip { label: "<crc32>"; clicked => { root.insert_tag("<crc32>"); } }
                            Chip { label: "<rand>";  clicked => { root.insert_tag("<rand>"); } }
                            Chip { label: "<rands>"; clicked => { root.insert_tag("<rands>"); } }
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<created>";  clicked => { root.insert_tag("<created>"); } }
                            Chip { label: "<modified>"; clicked => { root.insert_tag("<modified>"); } }
                            Chip { label: "<now>";      clicked => { root.insert_tag("<now>"); } }
                        }
                        Text {
                            text: "counters take :START:STEP · dates :FMT:OFFSET\nmods: |upper |lower |title |sub:0,3 |pad:4\n|trim |replace:a,b |fallback:x |+N |-N";
                            color: Palette.faint;
                            font-size: 10px;
                            font-family: "Cascadia Mono";
                        }
                    }

                    Rectangle { height: 6px; }
                    SectionTitle { text: "RULE STACK — RUNS TOP TO BOTTOM"; }

                    if root.rules.length == 0 : Text {
                        text: "no rules yet";
                        color: Palette.faint;
                        font-size: 12px;
                    }

                    for rule[i] in root.rules : Rectangle {
                        height: 40px;
                        border-radius: 6px;
                        background: Palette.inset;
                        border-width: 1px;
                        border-color: Palette.line-soft;
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 6px;
                            spacing: 8px;
                            VerticalLayout {
                                alignment: center;
                                spacing: 1px;
                                Text {
                                    text: rule.kind;
                                    color: Palette.amber;
                                    font-size: 9px;
                                    font-weight: 800;
                                    letter-spacing: 1.2px;
                                }
                                Text {
                                    text: rule.summary;
                                    color: Palette.text;
                                    font-size: 11px;
                                    font-family: "Cascadia Mono";
                                    overflow: elide;
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            VerticalLayout {
                                alignment: center;
                                HorizontalLayout {
                                    spacing: 2px;
                                    MiniButton { glyph: "▲"; clicked => { root.move_rule(i, i - 1); } }
                                    MiniButton { glyph: "▼"; clicked => { root.move_rule(i, i + 1); } }
                                    MiniButton { glyph: "×"; danger: true; clicked => { root.remove_rule(i); } }
                                }
                            }
                        }
                    }

                    Rectangle { vertical-stretch: 1; }

                    SectionTitle { text: "OUTPUT"; }
                    HorizontalLayout {
                        spacing: 6px;
                        Chip { label: "Rename"; active: root.batch_mode == "rename"; clicked => { root.batch_mode = "rename"; root.output_changed(); } }
                        Chip { label: "Copy";   active: root.batch_mode == "copy";   clicked => { root.batch_mode = "copy";   root.output_changed(); } }
                        Chip { label: "Move";   active: root.batch_mode == "move";   clicked => { root.batch_mode = "move";   root.output_changed(); } }
                    }
                    if root.batch_mode != "rename" : Field {
                        mono: true;
                        placeholder: "destination folder (tags ok)";
                        text <=> root.dest_text;
                        edited => { root.output_changed(); }
                    }
                    HorizontalLayout {
                        spacing: 6px;
                        Text {
                            text: "collide";
                            color: Palette.faint;
                            font-size: 10px;
                            vertical-alignment: center;
                        }
                        Chip { label: "fail"; active: root.collide == "fail";    clicked => { root.collide = "fail";    root.output_changed(); } }
                        Chip { label: "(2)";  active: root.collide == "number";  clicked => { root.collide = "number";  root.output_changed(); } }
                        Chip { label: "_b";   active: root.collide == "letter";  clicked => { root.collide = "letter";  root.output_changed(); } }
                        Chip { label: "tag";  active: root.collide == "pattern"; clicked => { root.collide = "pattern"; root.output_changed(); } }
                    }
                    if root.collide == "pattern" : Field {
                        mono: true;
                        placeholder: "suffix pattern, e.g. _<num>";
                        text <=> root.collide_pattern;
                        edited => { root.output_changed(); }
                    }

                    SectionTitle { text: "NUMBERING"; }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 52px;
                        VerticalLayout {
                            spacing: 4px;
                            alignment: start;
                            Text { text: "start"; color: Palette.dim; font-size: 10px; }
                            Field { text <=> root.start_text; mono: true; edited => { root.numbering_changed(); } }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            alignment: start;
                            Text { text: "pad (blank = auto)"; color: Palette.dim; font-size: 10px; }
                            Field { text <=> root.pad_text; mono: true; placeholder: "auto"; edited => { root.numbering_changed(); } }
                        }
                    }
                }
            }

            // ───────────────────────── right: file table
            VerticalLayout {
                padding: 0;
                spacing: 0;

                Rectangle {
                    height: root.selected_row >= 0 ? 132px : 92px;
                    VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 10px;
                        padding-bottom: 10px;
                        spacing: 8px;
                        HorizontalLayout {
                            spacing: 8px;
                            height: 30px;
                            ToolButton { label: "＋ Files";  width: 84px;  clicked => { root.pick_files(); } }
                            ToolButton { label: "＋ From folder"; width: 112px; clicked => { root.pick_folder(); } }
                            ToolButton { label: "＋ Folders"; width: 92px; clicked => { root.pick_dirs(); } }
                            ToolButton { label: "Clear"; danger: true; width: 64px; clicked => { root.clear_files(); } }
                            Rectangle { horizontal-stretch: 1; }
                            ToolButton { label: "Save list"; width: 84px; clicked => { root.save_list(); } }
                            ToolButton { label: "Load list"; width: 84px; clicked => { root.load_list(); } }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            height: 30px;
                            Field {
                                width: 170px;
                                placeholder: "search list";
                                text <=> root.search_text;
                                edited => { root.search_changed(); }
                            }
                            Field {
                                width: 190px;
                                mono: true;
                                placeholder: "masks: *.jpg;!*thumb*";
                                text <=> root.mask_text;
                            }
                            Chip { label: "recurse"; active: root.recurse; clicked => { root.recurse = !root.recurse; } }
                            Rectangle { horizontal-stretch: 1; }
                            Text {
                                text: "sort";
                                color: Palette.faint;
                                font-size: 10px;
                                vertical-alignment: center;
                            }
                            Chip { label: "name"; active: root.sort_by == "name"; clicked => { root.sort_by = "name"; root.sort_changed(); } }
                            Chip { label: "ext";  active: root.sort_by == "ext";  clicked => { root.sort_by = "ext";  root.sort_changed(); } }
                            Chip { label: "size"; active: root.sort_by == "size"; clicked => { root.sort_by = "size"; root.sort_changed(); } }
                            Chip { label: "date"; active: root.sort_by == "date"; clicked => { root.sort_by = "date"; root.sort_changed(); } }
                            Chip {
                                label: root.sort_desc ? "↓" : "↑";
                                active: root.sort_desc;
                                clicked => { root.sort_desc = !root.sort_desc; root.sort_changed(); }
                            }
                        }
                        if root.selected_row >= 0 : HorizontalLayout {
                            spacing: 8px;
                            height: 30px;
                            Text {
                                text: "row " + (root.selected_row + 1);
                                color: Palette.amber;
                                font-size: 11px;
                                font-family: "Cascadia Mono";
                                vertical-alignment: center;
                            }
                            Field {
                                horizontal-stretch: 1;
                                mono: true;
                                placeholder: "manual new name (blank = use rules)";
                                text <=> root.override_text;
                                edited => { root.set_override(); }
                            }
                            ToolButton { label: "▲"; width: 34px; clicked => { root.move_selected(-1); } }
                            ToolButton { label: "▼"; width: 34px; clicked => { root.move_selected(1); } }
                            ToolButton { label: "Remove"; danger: true; width: 76px; clicked => { root.remove_selected(); } }
                        }
                    }
                    Rectangle { y: parent.height - 1px; height: 1px; background: Palette.line-soft; }
                }

                // column header
                Rectangle {
                    height: 30px;
                    background: Palette.bg;
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 10px;
                        Text { text: "#"; width: 34px; color: Palette.faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; vertical-alignment: center; }
                        Text { text: "CURRENT"; horizontal-stretch: 1; color: Palette.faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; vertical-alignment: center; }
                        Text { text: ""; width: 20px; }
                        Text { text: "NEW"; horizontal-stretch: 1; color: Palette.faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; vertical-alignment: center; }
                        Text { text: "STATUS"; width: 90px; color: Palette.faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; vertical-alignment: center; }
                    }
                    Rectangle { y: parent.height - 1px; height: 1px; background: Palette.line-soft; }
                }

                if root.files.length == 0 : Rectangle {
                    vertical-stretch: 1;
                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        Text {
                            text: "→";
                            color: Palette.line;
                            font-size: 54px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "No files loaded — click ＋ Files or drop files here";
                            color: Palette.faint;
                            font-size: 13px;
                            horizontal-alignment: center;
                        }
                    }
                }

                if root.files.length > 0 : ListView {
                    vertical-stretch: 1;
                    for row in root.files : Rectangle {
                        height: 30px;
                        background: root.selected_row == row.index ? #ffa02818
                            : (touch.has-hover ? Palette.line-soft : (mod(row.index, 2) == 0 ? transparent : #14161b));
                        touch := TouchArea {
                            clicked => {
                                root.selected_row = root.selected_row == row.index ? -1 : row.index;
                                root.row_clicked(root.selected_row);
                            }
                        }
                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 10px;
                            Text {
                                text: row.index + 1;
                                width: 34px;
                                color: Palette.faint;
                                font-size: 11px;
                                font-family: "Cascadia Mono";
                                vertical-alignment: center;
                            }
                            Text {
                                text: row.old_name;
                                horizontal-stretch: 1;
                                color: row.state == 0 ? Palette.dim : Palette.text;
                                font-size: 12px;
                                font-family: "Cascadia Mono";
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            Text {
                                text: row.state == 0 ? "·" : "→";
                                width: 20px;
                                color: row.state == 2 ? Palette.error : (row.state == 1 ? Palette.amber : Palette.faint);
                                font-size: 12px;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: row.new_name;
                                horizontal-stretch: 1;
                                color: row.state == 2 ? Palette.error : (row.state == 1 ? Palette.amber : Palette.faint);
                                font-size: 12px;
                                font-family: "Cascadia Mono";
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            Text {
                                text: row.status;
                                width: 90px;
                                color: row.state == 2 ? Palette.error : Palette.faint;
                                font-size: 11px;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }

                // ───────────────────────── footer
                Rectangle {
                    height: 64px;
                    background: Palette.panel;
                    Rectangle { height: 1px; background: Palette.line-soft; }
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 14px;
                        padding-bottom: 14px;
                        spacing: 10px;
                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: root.status_text;
                                color: Palette.dim;
                                font-size: 12px;
                                font-family: "Cascadia Mono";
                                overflow: elide;
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        ToolButton {
                            label: "Undo last batch";
                            width: 140px;
                            height: 36px;
                            opacity: root.can_undo ? 1 : 0.35;
                            clicked => { if (root.can_undo) { root.undo_batch(); } }
                        }
                        Rectangle {
                            width: 190px;
                            height: 36px;
                            border-radius: 6px;
                            background: root.changed > 0 ? Palette.forge : Palette.line-soft;
                            drop-shadow-blur: root.changed > 0 ? 16px : 0;
                            drop-shadow-color: #ff5c3844;
                            Text {
                                text: root.changed > 0
                                    ? (root.batch_mode == "copy" ? "COPY " : root.batch_mode == "move" ? "MOVE " : "RENAME ") + root.changed + " FILES"
                                    : "NOTHING TO DO";
                                color: root.changed > 0 ? #17110b : Palette.faint;
                                font-size: 12px;
                                font-weight: 900;
                                letter-spacing: 1.4px;
                                width: 100%;
                                height: 100%;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            apply-ta := TouchArea { clicked => { if (root.changed > 0) { root.apply_batch(); } } }
                        }
                    }
                }
            }
        }
    }
}
