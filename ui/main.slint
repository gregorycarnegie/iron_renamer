// Iron Renamer — forge-industrial theme.
// Deep steel darks, molten amber accent, monospace filenames, live preview.

import { ListView, TextEdit, ScrollView } from "std-widgets.slint";

export struct FileRow {
    index: int,
    old_name: string,
    new_name: string,
    dir: string,
    status: string,
    state: int, // 0 unchanged, 1 changed, 2 error
}

export struct RuleRow {
    kind: string,
    summary: string,
}

global Palette {
    out property <color> bg: #0f1114;
    out property <color> panel: #16191e;
    out property <color> inset: #0b0d10;
    out property <color> line: #262b33;
    out property <color> line-soft: #1d2127;
    out property <color> text: #e8e4db;
    out property <color> dim: #7d8593;
    out property <color> faint: #4a515c;
    out property <color> amber: #ffa028;
    out property <color> ember: #ff5c38;
    out property <color> error: #ff6259;
    out property <brush> forge: @linear-gradient(135deg, #ffa028 0%, #ff5c38 100%);
}

component Field inherits Rectangle {
    in property <string> placeholder;
    in-out property <string> text <=> ti.text;
    in property <bool> mono: false;
    callback edited();
    public function grab() { ti.focus(); }
    height: 30px;
    background: Palette.inset;
    border-radius: 5px;
    border-width: 1px;
    border-color: ti.has-focus ? Palette.amber : Palette.line;
    animate border-color { duration: 120ms; }
    ti := TextInput {
        x: 10px;
        width: parent.width - 20px;
        height: 100%;
        vertical-alignment: center;
        color: Palette.text;
        font-size: 12px;
        font-family: root.mono ? "Cascadia Mono" : "Segoe UI";
        selection-background-color: #ffa02855;
        edited => { root.edited(); }
    }
    if ti.text == "" && !ti.has-focus : Text {
        x: 10px;
        height: 100%;
        text: root.placeholder;
        color: Palette.faint;
        font-size: 12px;
        vertical-alignment: center;
    }
}

component Chip inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked();
    height: 26px;
    border-radius: 13px;
    background: active ? #ffa02820 : (ta.has-hover ? Palette.line-soft : transparent);
    border-width: 1px;
    border-color: active ? Palette.amber : Palette.line;
    animate background, border-color { duration: 120ms; }
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        Text {
            text: root.label;
            color: root.active ? Palette.amber : Palette.dim;
            font-size: 11px;
            font-weight: root.active ? 700 : 400;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component ToolButton inherits Rectangle {
    in property <string> label;
    in property <bool> danger: false;
    callback clicked();
    height: 26px;
    border-radius: 5px;
    background: ta.has-hover ? (danger ? #ff625915 : Palette.line-soft) : transparent;
    border-width: 1px;
    border-color: ta.has-hover ? (danger ? #ff625966 : Palette.line) : Palette.line-soft;
    animate background, border-color { duration: 120ms; }
    HorizontalLayout {
        padding-left: 11px;
        padding-right: 11px;
        Text {
            text: root.label;
            color: root.danger ? Palette.error : Palette.text;
            font-size: 11px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component MiniButton inherits Rectangle {
    in property <string> glyph;
    in property <bool> danger: false;
    callback clicked();
    width: 22px;
    height: 22px;
    border-radius: 4px;
    background: ta.has-hover ? (danger ? #ff625922 : Palette.line) : transparent;
    Text {
        text: root.glyph;
        color: ta.has-hover ? (root.danger ? Palette.error : Palette.text) : Palette.dim;
        font-size: 11px;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// Native-style caption button (minimize/maximize/close) for the frameless
// window. Icons are stroked paths — glyph fonts aren't reliable cross-platform.
component WinButton inherits Rectangle {
    in property <string> icon; // SVG path commands in a 10×10 viewbox
    in property <bool> danger: false;
    callback clicked();
    width: 44px;
    background: ta.has-hover ? (danger ? #e81123 : Palette.line) : transparent;
    animate background { duration: 100ms; }
    Path {
        width: 10px;
        height: 10px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        viewbox-width: 10;
        viewbox-height: 10;
        commands: root.icon;
        stroke: ta.has-hover ? (root.danger ? white : Palette.text) : Palette.dim;
        stroke-width: 1px;
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// Invisible strip along a window edge that starts a native resize drag.
component EdgeGrip inherits TouchArea {
    in property <string> dir;
    callback resize(string);
    pointer-event(ev) => {
        if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
            root.resize(root.dir);
        }
    }
}

component SectionTitle inherits Text {
    color: Palette.faint;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.6px;
}

export component MainWindow inherits Window {
    title: "Iron Renamer";
    icon: @image-url("icon.png");
    no-frame: root.frameless;
    background: Palette.bg;
    preferred-width: 1180px;
    preferred-height: 740px;
    min-width: 1010px;
    min-height: 560px;
    default-font-family: "Segoe UI";

    in property <[FileRow]> files: [];
    in property <[RuleRow]> rules: [];
    in property <int> total: 0;
    in property <int> changed: 0;
    in property <int> errors: 0;
    in property <string> status_text: "add files, stack rules, forge names.";
    in property <bool> can_undo: false;
    in property <string> app_version: "";
    in-out property <bool> show_about: false;

    // Custom title bar: frameless on Windows/Linux, native frame on macOS.
    // Min/max use the builtin Window.minimized/maximized properties (winit
    // backend keeps them in sync); close/drag/resize need native calls in Rust.
    in property <bool> frameless: false;
    callback win_close();
    callback win_drag();
    callback win_resize(string);
    callback open_url(string);

    in-out property <string> new_kind: "replace";
    in-out property <string> field_a: "";
    in-out property <string> field_b: "";
    in-out property <string> case_mode: "lower";
    in-out property <string> apply_part: "both";
    in-out property <bool> replace_cs: false;
    in-out property <string> replace_occ: "all";
    in-out property <bool> pairs_cs: false;
    in-out property <string> trim_at: "both";
    in-out property <bool> trim_inv: false;
    in-out property <string> start_text: "1";
    in-out property <string> pad_text: "";

    callback pick_files();
    callback pick_folder();
    callback pick_dirs();
    callback clear_files();
    callback add_rule();
    callback remove_rule(int);
    callback clear_rules();
    callback move_rule(int, int);
    callback edit_rule(int);   // click a stack row: load it into the form
    callback cancel_edit();
    in-out property <int> editing_rule: -1;
    callback apply_batch();
    callback undo_batch();
    callback settings_changed();
    callback insert_tag(string);
    callback row_clicked(int);
    callback save_list();
    callback load_list();
    callback remove_selected();
    callback move_selected(int);
    callback set_override();
    callback sort_changed();
    in-out property <bool> show_tags: false;
    in-out property <int> selected_row: -1;
    in-out property <string> search_text: "";
    in-out property <string> mask_text: "";
    in-out property <bool> recurse: false;
    in-out property <string> sort_by: "manual";
    in-out property <bool> sort_desc: false;
    in-out property <string> override_text: "";
    in-out property <string> batch_mode: "rename";
    in-out property <string> dest_text: "";
    in-out property <string> collide: "fail";
    in-out property <string> collide_pattern: "";
    in-out property <bool> pairs: false;
    in-out property <string> touch_text: "";
    callback import_csv();
    callback export_preview();
    callback save_preset();
    callback load_preset();

    forward-focus: keys;

    keys := FocusScope {
        key-pressed(e) => {
            if (e.modifiers.control && e.text == "o") { root.pick_files(); return accept; }
            if (e.modifiers.control && e.text == "f") { search-field.grab(); return accept; }
            if (e.modifiers.control && e.text == "z") { if (root.can_undo) { root.undo_batch(); } return accept; }
            if (e.modifiers.control && e.text == Key.Return) { if (root.changed > 0) { root.apply_batch(); } return accept; }
            if (e.text == Key.F2) { if (root.selected_row >= 0) { override-field.grab(); } return accept; }
            if (e.text == Key.Delete) { if (root.selected_row >= 0) { root.remove_selected(); } return accept; }
            if (e.text == Key.Escape) {
                if (root.show_about) { root.show_about = false; return accept; }
                root.selected_row = -1;
                root.row_clicked(-1);
                return accept;
            }
            if (e.text == Key.UpArrow) {
                if (e.modifiers.control) { root.move_selected(-1); }
                else if (root.files.length > 0) {
                    root.selected_row = max(0, root.selected_row - 1);
                    root.row_clicked(root.selected_row);
                }
                return accept;
            }
            if (e.text == Key.DownArrow) {
                if (e.modifiers.control) { root.move_selected(1); }
                else if (root.files.length > 0) {
                    root.selected_row = min(root.files.length - 1, root.selected_row + 1);
                    root.row_clicked(root.selected_row);
                }
                return accept;
            }
            reject
        }

    VerticalLayout {
        padding: 0;
        spacing: 0;

        // ───────────────────────── header
        Rectangle {
            height: 62px;
            background: Palette.panel;
            Rectangle { y: parent.height - 1px; height: 1px; background: Palette.line-soft; }
            // The whole header is the title bar; buttons declared later sit on top.
            if root.frameless : TouchArea {
                pointer-event(ev) => {
                    if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                        root.win_drag();
                    }
                }
            }
            HorizontalLayout {
                padding-left: 18px;
                padding-right: root.frameless ? 150px : 18px;
                spacing: 14px;
                Rectangle {
                    width: 34px;
                    height: 34px;
                    y: (parent.height - self.height) / 2;
                    border-radius: 8px;
                    background: Palette.forge;
                    drop-shadow-blur: 18px;
                    drop-shadow-color: #ff5c3855;
                    Image {
                        width: 100%;
                        height: 100%;
                        source: @image-url("icon.png");
                    }
                }
                VerticalLayout {
                    alignment: center;
                    spacing: 1px;
                    Text {
                        text: "IRON RENAMER";
                        color: Palette.text;
                        font-size: 15px;
                        font-weight: 800;
                        letter-spacing: 3px;
                    }
                    Text {
                        text: "batch rename · live preview";
                        color: Palette.faint;
                        font-size: 10px;
                        letter-spacing: 1px;
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: root.total == 0 ? "no files loaded"
                            : root.changed + " of " + root.total + " will change"
                              + (root.errors > 0 ? "  ·  " + root.errors + " conflicts" : "");
                        color: root.errors > 0 ? Palette.error : Palette.dim;
                        font-size: 12px;
                        font-family: "Cascadia Mono";
                    }
                }
                VerticalLayout {
                    alignment: center;
                    MiniButton { glyph: "?"; clicked => { root.show_about = true; } }
                }
            }
            if root.frameless : HorizontalLayout {
                width: 132px; // 3 × 44px — explicit, or the layout fills the header
                x: parent.width - self.width;
                y: 0;
                height: 30px;
                WinButton { icon: "M 0 5 L 10 5"; clicked => { root.minimized = true; } }
                WinButton {
                    icon: root.maximized
                        ? "M 0.5 2.5 L 7.5 2.5 L 7.5 9.5 L 0.5 9.5 Z M 2.5 2.5 L 2.5 0.5 L 9.5 0.5 L 9.5 7.5 L 7.5 7.5"
                        : "M 0.5 0.5 L 9.5 0.5 L 9.5 9.5 L 0.5 9.5 Z";
                    clicked => { root.maximized = !root.maximized; }
                }
                WinButton { icon: "M 0 0 L 10 10 M 10 0 L 0 10"; danger: true; clicked => { root.win_close(); } }
            }
        }

        HorizontalLayout {
            padding: 0;
            spacing: 0;

            // ───────────────────────── left rail: rules
            Rectangle {
                width: 312px;
                background: Palette.panel;

                // Whole rail scrolls so nothing clips at small window sizes;
                // pinned to at least the visible height so OUTPUT stays at the bottom.
                sv := ScrollView {
                    width: 100%;
                    height: 100%;
                rail := VerticalLayout {
                    width: sv.visible-width;
                    height: max(sv.visible-height, self.min-height);
                    padding: 16px;
                    spacing: 10px;

                    SectionTitle { text: "NEW RULE"; }

                    VerticalLayout {
                        spacing: 6px;
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "Replace";      active: root.new_kind == "replace"; clicked => { root.new_kind = "replace"; } }
                            Chip { label: "List Replace"; active: root.new_kind == "pairs";   clicked => { root.new_kind = "pairs"; } }
                            Chip { label: "Regex";        active: root.new_kind == "regex";   clicked => { root.new_kind = "regex"; } }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "Case";    active: root.new_kind == "case";    clicked => { root.new_kind = "case"; } }
                            Chip { label: "Pattern"; active: root.new_kind == "pattern"; clicked => { root.new_kind = "pattern"; } }
                            Chip { label: "Insert";  active: root.new_kind == "insert";  clicked => { root.new_kind = "insert"; } }
                            Chip { label: "Remove";  active: root.new_kind == "remove";  clicked => { root.new_kind = "remove"; } }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "Trim";     active: root.new_kind == "trim";     clicked => { root.new_kind = "trim"; } }
                            Chip { label: "Renumber"; active: root.new_kind == "renumber"; clicked => { root.new_kind = "renumber"; } }
                            Chip { label: "Move";     active: root.new_kind == "move";     clicked => { root.new_kind = "move"; } }
                            Chip { label: "Swap";     active: root.new_kind == "swap";     clicked => { root.new_kind = "swap"; } }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "Names"; active: root.new_kind == "names"; clicked => { root.new_kind = "names"; } }
                            Chip { label: "JS";    active: root.new_kind == "js";    clicked => { root.new_kind = "js"; } }
                        }
                    }

                    if root.new_kind == "replace" || root.new_kind == "regex" : VerticalLayout {
                        spacing: 8px;
                        Field {
                            placeholder: root.new_kind == "replace" ? "find text" : "regex pattern";
                            mono: true;
                            text <=> root.field_a;
                        }
                        Field {
                            placeholder: root.new_kind == "replace" ? "replace with (tags ok)" : "replacement ($1, $2…)";
                            mono: true;
                            text <=> root.field_b;
                        }
                    }

                    if root.new_kind == "replace" : HorizontalLayout {
                        spacing: 6px;
                        Chip { label: "Aa";    active: root.replace_cs;           clicked => { root.replace_cs = !root.replace_cs; } }
                        Chip { label: "all";   active: root.replace_occ == "all";   clicked => { root.replace_occ = "all"; } }
                        Chip { label: "first"; active: root.replace_occ == "first"; clicked => { root.replace_occ = "first"; } }
                        Chip { label: "last";  active: root.replace_occ == "last";  clicked => { root.replace_occ = "last"; } }
                    }

                    if root.new_kind == "case" : VerticalLayout {
                        spacing: 6px;
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "lower";  active: root.case_mode == "lower"; clicked => { root.case_mode = "lower"; } }
                            Chip { label: "UPPER";  active: root.case_mode == "upper"; clicked => { root.case_mode = "upper"; } }
                            Chip { label: "Title";  active: root.case_mode == "title"; clicked => { root.case_mode = "title"; } }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "First";  active: root.case_mode == "first";  clicked => { root.case_mode = "first"; } }
                            Chip { label: "iNVERT"; active: root.case_mode == "invert"; clicked => { root.case_mode = "invert"; } }
                        }
                        Field {
                            placeholder: "scope: at:2,3 · re:PAT · text (blank = all)";
                            mono: true;
                            text <=> root.field_b;
                        }
                    }

                    if root.new_kind == "pattern" : VerticalLayout {
                        spacing: 6px;
                        Field {
                            placeholder: "e.g. trip_<num>.<ext>";
                            mono: true;
                            text <=> root.field_a;
                        }
                        Text {
                            text: "<name> <ext> <num> <index> <parent>";
                            color: Palette.faint;
                            font-size: 10px;
                            font-family: "Cascadia Mono";
                        }
                    }

                    if root.new_kind == "insert" || root.new_kind == "move" : VerticalLayout {
                        spacing: 6px;
                        Field {
                            placeholder: root.new_kind == "insert" ? "text to insert (tags ok)" : "text to move (re:PAT for regex)";
                            mono: true;
                            text <=> root.field_a;
                        }
                        Field {
                            placeholder: "position (blank = end)";
                            mono: true;
                            text <=> root.field_b;
                        }
                        Text {
                            text: "start · end · 2 · -1 · before:txt · after:txt\nrbefore:PAT · rafter:PAT";
                            color: Palette.faint;
                            font-size: 10px;
                            font-family: "Cascadia Mono";
                        }
                    }

                    if root.new_kind == "remove" : VerticalLayout {
                        spacing: 6px;
                        Field {
                            placeholder: "what to remove";
                            mono: true;
                            text <=> root.field_a;
                        }
                        Text {
                            text: "text · re:PAT · pos:2,3 · chars:_-\ndigits · upper · lower · diacritics";
                            color: Palette.faint;
                            font-size: 10px;
                            font-family: "Cascadia Mono";
                        }
                    }

                    if root.new_kind == "trim" : VerticalLayout {
                        spacing: 6px;
                        Field {
                            placeholder: "characters (blank = whitespace)";
                            mono: true;
                            text <=> root.field_a;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "start"; active: root.trim_at == "start"; clicked => { root.trim_at = "start"; } }
                            Chip { label: "end";   active: root.trim_at == "end";   clicked => { root.trim_at = "end"; } }
                            Chip { label: "both";  active: root.trim_at == "both";  clicked => { root.trim_at = "both"; } }
                            Chip { label: "all";   active: root.trim_at == "all";   clicked => { root.trim_at = "all"; } }
                            Chip { label: "inv";   active: root.trim_inv;           clicked => { root.trim_inv = !root.trim_inv; } }
                        }
                    }

                    if root.new_kind == "renumber" : VerticalLayout {
                        spacing: 6px;
                        Field {
                            placeholder: "which number (1 = first)";
                            mono: true;
                            text <=> root.field_a;
                        }
                        Field {
                            placeholder: "+5 · -3 · 10 · 10/2 (start/step)";
                            mono: true;
                            text <=> root.field_b;
                        }
                    }

                    if root.new_kind == "swap" : Field {
                        placeholder: "separator, e.g. \" - \"";
                        mono: true;
                        text <=> root.field_a;
                    }

                    if root.new_kind == "names" : VerticalLayout {
                        spacing: 6px;
                        TextEdit {
                            height: 90px;
                            font-size: 12px;
                            text <=> root.field_a;
                        }
                        Text {
                            text: "one new name per line, in list order";
                            color: Palette.faint;
                            font-size: 10px;
                            font-family: "Cascadia Mono";
                        }
                    }

                    if root.new_kind == "pairs" : VerticalLayout {
                        spacing: 6px;
                        TextEdit {
                            height: 90px;
                            font-size: 12px;
                            text <=> root.field_a;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Chip { label: "Aa"; active: root.pairs_cs; clicked => { root.pairs_cs = !root.pairs_cs; } }
                            Text {
                                text: "one OLD=NEW per line (tags ok in NEW)";
                                color: Palette.faint;
                                font-size: 10px;
                                font-family: "Cascadia Mono";
                                vertical-alignment: center;
                            }
                        }
                    }

                    if root.new_kind == "js" : VerticalLayout {
                        spacing: 6px;
                        TextEdit {
                            height: 90px;
                            font-size: 12px;
                            text <=> root.field_a;
                        }
                        Text {
                            text: "sandboxed script; last expression = new name\nglobals: name ext stem original path index num";
                            color: Palette.faint;
                            font-size: 10px;
                            font-family: "Cascadia Mono";
                        }
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        Text {
                            text: "apply to";
                            color: Palette.faint;
                            font-size: 10px;
                            vertical-alignment: center;
                        }
                        Chip { label: "name+ext"; active: root.apply_part == "both"; clicked => { root.apply_part = "both"; } }
                        Chip { label: "name";     active: root.apply_part == "name"; clicked => { root.apply_part = "name"; } }
                        Chip { label: "ext";      active: root.apply_part == "ext";  clicked => { root.apply_part = "ext"; } }
                    }

                    Rectangle {
                        height: 32px;
                        border-radius: 5px;
                        background: add-ta.has-hover ? #ffa02830 : #ffa02818;
                        border-width: 1px;
                        border-color: #ffa02866;
                        animate background { duration: 120ms; }
                        Text {
                            text: root.editing_rule >= 0 ? "✓ SAVE RULE" : "+ ADD RULE";
                            color: Palette.amber;
                            font-size: 11px;
                            font-weight: 800;
                            letter-spacing: 1.4px;
                            width: 100%;
                            height: 100%;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        add-ta := TouchArea { clicked => { root.add_rule(); } }
                    }

                    if root.editing_rule >= 0 : Chip {
                        label: "✕ cancel edit";
                        clicked => { root.cancel_edit(); }
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        SectionTitle { text: "TAGS"; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Chip {
                            label: root.show_tags ? "hide" : "show";
                            active: root.show_tags;
                            clicked => { root.show_tags = !root.show_tags; }
                        }
                    }

                    if root.show_tags : VerticalLayout {
                        spacing: 4px;
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<name>";  clicked => { root.insert_tag("<name>"); } }
                            Chip { label: "<ext>";   clicked => { root.insert_tag("<ext>"); } }
                            Chip { label: "<num>";   clicked => { root.insert_tag("<num>"); } }
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<oname>"; clicked => { root.insert_tag("<oname>"); } }
                            Chip { label: "<oext>";  clicked => { root.insert_tag("<oext>"); } }
                            Chip { label: "<index>"; clicked => { root.insert_tag("<index>"); } }
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<parent>"; clicked => { root.insert_tag("<parent>"); } }
                            Chip { label: "<path>";   clicked => { root.insert_tag("<path>"); } }
                            Chip { label: "<dirnum>"; clicked => { root.insert_tag("<dirnum>"); } }
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<alpha>"; clicked => { root.insert_tag("<alpha>"); } }
                            Chip { label: "<hex>";   clicked => { root.insert_tag("<hex>"); } }
                            Chip { label: "<roman>"; clicked => { root.insert_tag("<roman>"); } }
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<size>";  clicked => { root.insert_tag("<size>"); } }
                            Chip { label: "<crc32>"; clicked => { root.insert_tag("<crc32>"); } }
                            Chip { label: "<rand>";  clicked => { root.insert_tag("<rand>"); } }
                            Chip { label: "<rands>"; clicked => { root.insert_tag("<rands>"); } }
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<created>";  clicked => { root.insert_tag("<created>"); } }
                            Chip { label: "<modified>"; clicked => { root.insert_tag("<modified>"); } }
                            Chip { label: "<now>";      clicked => { root.insert_tag("<now>"); } }
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<width>";  clicked => { root.insert_tag("<width>"); } }
                            Chip { label: "<height>"; clicked => { root.insert_tag("<height>"); } }
                            Chip { label: "<datetaken>"; clicked => { root.insert_tag("<datetaken>"); } }
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            Chip { label: "<artist>"; clicked => { root.insert_tag("<artist>"); } }
                            Chip { label: "<album>";  clicked => { root.insert_tag("<album>"); } }
                            Chip { label: "<track>";  clicked => { root.insert_tag("<track>"); } }
                            Chip { label: "<title>";  clicked => { root.insert_tag("<title>"); } }
                        }
                        Text {
                            text: "counters take :START:STEP · dates :FMT:OFFSET\nmedia + <exif:TAG> need ExifTool on PATH\nmods: |upper |lower |title |sub:0,3 |pad:4\n|trim |replace:a,b |fallback:x |+N |-N";
                            color: Palette.faint;
                            font-size: 10px;
                            font-family: "Cascadia Mono";
                        }
                    }

                    Rectangle { height: 6px; }
                    HorizontalLayout {
                        spacing: 6px;
                        SectionTitle { text: "RULE STACK"; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Chip { label: "save"; clicked => { root.save_preset(); } }
                        Chip { label: "load"; clicked => { root.load_preset(); } }
                        Chip { label: "clear"; clicked => { root.clear_rules(); } }
                    }

                    if root.rules.length == 0 : Text {
                        text: "no rules yet — applied top to bottom";
                        color: Palette.faint;
                        font-size: 12px;
                    }

                    // Scrolls on its own past 5 rules so OUTPUT stays reachable.
                    if root.rules.length > 0 : ListView {
                        height: min(root.rules.length, 5) * 44px;
                        for rule[i] in root.rules : Rectangle {
                        height: 44px;
                        Rectangle {
                        y: 0;
                        width: parent.width;
                        height: 40px;
                        border-radius: 6px;
                        background: Palette.inset;
                        border-width: 1px;
                        border-color: i == root.editing_rule ? Palette.amber : Palette.line-soft;
                        // Click a row to edit it in the form (buttons stay on top).
                        TouchArea { clicked => { root.edit_rule(i); } }
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 6px;
                            spacing: 8px;
                            VerticalLayout {
                                alignment: center;
                                spacing: 1px;
                                Text {
                                    text: rule.kind;
                                    color: Palette.amber;
                                    font-size: 9px;
                                    font-weight: 800;
                                    letter-spacing: 1.2px;
                                }
                                Text {
                                    text: rule.summary;
                                    color: Palette.text;
                                    font-size: 11px;
                                    font-family: "Cascadia Mono";
                                    overflow: elide;
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            VerticalLayout {
                                alignment: center;
                                HorizontalLayout {
                                    spacing: 2px;
                                    MiniButton { glyph: "▲"; clicked => { root.move_rule(i, i - 1); } }
                                    MiniButton { glyph: "▼"; clicked => { root.move_rule(i, i + 1); } }
                                    MiniButton { glyph: "×"; danger: true; clicked => { root.remove_rule(i); } }
                                }
                            }
                        }
                        }
                        }
                    }

                    Rectangle { vertical-stretch: 1; }

                    SectionTitle { text: "OUTPUT"; }
                    HorizontalLayout {
                        spacing: 6px;
                        Chip { label: "Rename"; active: root.batch_mode == "rename"; clicked => { root.batch_mode = "rename"; root.settings_changed(); } }
                        Chip { label: "Copy";   active: root.batch_mode == "copy";   clicked => { root.batch_mode = "copy";   root.settings_changed(); } }
                        Chip { label: "Move";   active: root.batch_mode == "move";   clicked => { root.batch_mode = "move";   root.settings_changed(); } }
                    }
                    if root.batch_mode != "rename" : Field {
                        mono: true;
                        placeholder: "destination folder (tags ok)";
                        text <=> root.dest_text;
                        edited => { root.settings_changed(); }
                    }
                    HorizontalLayout {
                        spacing: 6px;
                        Text {
                            text: "collide";
                            color: Palette.faint;
                            font-size: 10px;
                            vertical-alignment: center;
                        }
                        Chip { label: "fail"; active: root.collide == "fail";    clicked => { root.collide = "fail";    root.settings_changed(); } }
                        Chip { label: "(2)";  active: root.collide == "number";  clicked => { root.collide = "number";  root.settings_changed(); } }
                        Chip { label: "_b";   active: root.collide == "letter";  clicked => { root.collide = "letter";  root.settings_changed(); } }
                        Chip { label: "tag";  active: root.collide == "pattern"; clicked => { root.collide = "pattern"; root.settings_changed(); } }
                    }
                    if root.collide == "pattern" : Field {
                        mono: true;
                        placeholder: "suffix pattern, e.g. _<num>";
                        text <=> root.collide_pattern;
                        edited => { root.settings_changed(); }
                    }
                    Field {
                        mono: true;
                        placeholder: "timestamps: modified=+1h · all=exif";
                        text <=> root.touch_text;
                    }

                    SectionTitle { text: "NUMBERING"; }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 52px;
                        VerticalLayout {
                            spacing: 4px;
                            alignment: start;
                            Text { text: "start"; color: Palette.dim; font-size: 10px; }
                            Field { text <=> root.start_text; mono: true; edited => { root.settings_changed(); } }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            alignment: start;
                            Text { text: "pad (blank = auto)"; color: Palette.dim; font-size: 10px; }
                            Field { text <=> root.pad_text; mono: true; placeholder: "auto"; edited => { root.settings_changed(); } }
                        }
                    }
                }
                }
                Rectangle { x: parent.width - 1px; width: 1px; background: Palette.line-soft; }
            }

            // ───────────────────────── right: file table
            VerticalLayout {
                padding: 0;
                spacing: 0;

                Rectangle {
                    height: 122px;
                    VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 10px;
                        padding-bottom: 10px;
                        spacing: 8px;
                        HorizontalLayout {
                            spacing: 6px;
                            height: 26px;
                            ToolButton { label: "＋ Files";  clicked => { root.pick_files(); } }
                            ToolButton { label: "＋ From folder"; clicked => { root.pick_folder(); } }
                            ToolButton { label: "＋ Folders"; clicked => { root.pick_dirs(); } }
                            ToolButton { label: "Clear"; danger: true; clicked => { root.clear_files(); } }
                            Rectangle { horizontal-stretch: 1; }
                            ToolButton { label: "Import CSV"; clicked => { root.import_csv(); } }
                            ToolButton { label: "Export"; clicked => { root.export_preview(); } }
                            ToolButton { label: "Save list"; clicked => { root.save_list(); } }
                            ToolButton { label: "Load list"; clicked => { root.load_list(); } }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            height: 30px;
                            // Shrink before anything clips; the spacer eats surplus.
                            search-field := Field {
                                min-width: 120px;
                                max-width: 170px;
                                horizontal-stretch: 1;
                                placeholder: "search list  (Ctrl+F)";
                                text <=> root.search_text;
                                edited => { root.settings_changed(); }
                            }
                            Field {
                                min-width: 130px;
                                max-width: 190px;
                                horizontal-stretch: 1;
                                mono: true;
                                placeholder: "masks: *.jpg;!*thumb*";
                                text <=> root.mask_text;
                            }
                            Chip { label: "recurse"; active: root.recurse; clicked => { root.recurse = !root.recurse; } }
                            Chip { label: "pairs"; active: root.pairs; clicked => { root.pairs = !root.pairs; root.settings_changed(); } }
                            Rectangle { horizontal-stretch: 1; }
                            Text {
                                text: "sort";
                                color: Palette.faint;
                                font-size: 10px;
                                vertical-alignment: center;
                            }
                            Chip { label: "name"; active: root.sort_by == "name"; clicked => { root.sort_by = "name"; root.sort_changed(); } }
                            Chip { label: "ext";  active: root.sort_by == "ext";  clicked => { root.sort_by = "ext";  root.sort_changed(); } }
                            Chip { label: "size"; active: root.sort_by == "size"; clicked => { root.sort_by = "size"; root.sort_changed(); } }
                            Chip { label: "date"; active: root.sort_by == "date"; clicked => { root.sort_by = "date"; root.sort_changed(); } }
                            Chip {
                                label: root.sort_desc ? "↓" : "↑";
                                active: root.sort_desc;
                                clicked => { root.sort_desc = !root.sort_desc; root.sort_changed(); }
                            }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            height: 30px;
                            Text {
                                text: root.selected_row >= 0 ? "row " + (root.selected_row + 1) : "no row";
                                width: 52px;
                                color: root.selected_row >= 0 ? Palette.amber : Palette.faint;
                                font-size: 11px;
                                font-family: "Cascadia Mono";
                                vertical-alignment: center;
                            }
                            override-field := Field {
                                horizontal-stretch: 1;
                                mono: true;
                                placeholder: root.selected_row >= 0
                                    ? "manual new name (blank = use rules)  (F2)"
                                    : "click a row to select — ↑/↓ move selection, Ctrl+↑/↓ reorder, Del removes";
                                text <=> root.override_text;
                                edited => { root.set_override(); }
                            }
                            ToolButton { label: "▲"; width: 34px; height: 30px; clicked => { root.move_selected(-1); } }
                            ToolButton { label: "▼"; width: 34px; height: 30px; clicked => { root.move_selected(1); } }
                            ToolButton { label: "Remove"; danger: true; height: 30px; clicked => { root.remove_selected(); } }
                        }
                    }
                    Rectangle { y: parent.height - 1px; height: 1px; background: Palette.line-soft; }
                }

                // column header
                Rectangle {
                    height: 30px;
                    background: Palette.bg;
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 10px;
                        Text { text: "#"; width: 34px; color: Palette.faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; vertical-alignment: center; }
                        Text { text: "CURRENT"; horizontal-stretch: 1; color: Palette.faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; vertical-alignment: center; }
                        Text { text: ""; width: 20px; }
                        Text { text: "NEW"; horizontal-stretch: 1; color: Palette.faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; vertical-alignment: center; }
                        Text { text: "STATUS"; width: 90px; color: Palette.faint; font-size: 10px; font-weight: 700; letter-spacing: 1px; vertical-alignment: center; }
                    }
                    Rectangle { y: parent.height - 1px; height: 1px; background: Palette.line-soft; }
                }

                if root.files.length == 0 : Rectangle {
                    vertical-stretch: 1;
                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        Text {
                            text: "→";
                            color: Palette.line;
                            font-size: 54px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "No files loaded — click ＋ Files (Ctrl+O) or drop files here";
                            color: Palette.faint;
                            font-size: 13px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "Ctrl+F search · ↑/↓ select · Ctrl+↑/↓ reorder · Del remove · F2 override · Ctrl+Z undo · Ctrl+Enter start";
                            color: Palette.faint;
                            font-size: 11px;
                            horizontal-alignment: center;
                        }
                    }
                }

                if root.files.length > 0 : ListView {
                    vertical-stretch: 1;
                    for row in root.files : Rectangle {
                        height: 30px;
                        background: root.selected_row == row.index ? #ffa02818
                            : (touch.has-hover ? Palette.line-soft : (mod(row.index, 2) == 0 ? transparent : #14161b));
                        touch := TouchArea {
                            clicked => {
                                root.selected_row = root.selected_row == row.index ? -1 : row.index;
                                root.row_clicked(root.selected_row);
                            }
                        }
                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 10px;
                            Text {
                                text: row.index + 1;
                                width: 34px;
                                color: Palette.faint;
                                font-size: 11px;
                                font-family: "Cascadia Mono";
                                vertical-alignment: center;
                            }
                            Text {
                                text: row.old_name;
                                horizontal-stretch: 1;
                                color: row.state == 0 ? Palette.dim : Palette.text;
                                font-size: 12px;
                                font-family: "Cascadia Mono";
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            Text {
                                text: row.state == 0 ? "·" : "→";
                                width: 20px;
                                color: row.state == 2 ? Palette.error : (row.state == 1 ? Palette.amber : Palette.faint);
                                font-size: 12px;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: row.new_name;
                                horizontal-stretch: 1;
                                color: row.state == 2 ? Palette.error : (row.state == 1 ? Palette.amber : Palette.faint);
                                font-size: 12px;
                                font-family: "Cascadia Mono";
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            Text {
                                text: row.status;
                                width: 90px;
                                color: row.state == 2 ? Palette.error : Palette.faint;
                                font-size: 11px;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }

                // ───────────────────────── footer
                Rectangle {
                    height: 64px;
                    background: Palette.panel;
                    Rectangle { y: 0; height: 1px; background: Palette.line-soft; }
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 14px;
                        padding-bottom: 14px;
                        spacing: 10px;
                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: root.status_text;
                                color: Palette.dim;
                                font-size: 12px;
                                font-family: "Cascadia Mono";
                                overflow: elide;
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        ToolButton {
                            label: "Undo last batch";
                            width: 140px;
                            height: 36px;
                            opacity: root.can_undo ? 1 : 0.35;
                            clicked => { if (root.can_undo) { root.undo_batch(); } }
                        }
                        Rectangle {
                            width: 190px;
                            height: 36px;
                            border-radius: 6px;
                            background: root.changed > 0 ? Palette.forge : Palette.line-soft;
                            drop-shadow-blur: root.changed > 0 ? 16px : 0;
                            drop-shadow-color: #ff5c3844;
                            Text {
                                text: root.changed > 0
                                    ? (root.batch_mode == "copy" ? "COPY " : root.batch_mode == "move" ? "MOVE " : "RENAME ") + root.changed + " FILES"
                                    : "NOTHING TO DO";
                                color: root.changed > 0 ? #17110b : Palette.faint;
                                font-size: 12px;
                                font-weight: 900;
                                letter-spacing: 1.4px;
                                width: 100%;
                                height: 100%;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            apply-ta := TouchArea { clicked => { if (root.changed > 0) { root.apply_batch(); } } }
                        }
                    }
                }
            }
        }
    }
    }

    // ───────────────────────── about dialog
    if root.show_about : Rectangle {
        background: #000000aa;
        TouchArea { clicked => { root.show_about = false; } }
        Rectangle {
            width: 340px;
            height: about-content.min-height;
            border-radius: 8px;
            background: Palette.panel;
            border-width: 1px;
            border-color: Palette.line;
            drop-shadow-blur: 30px;
            drop-shadow-color: #00000088;
            TouchArea { } // swallow clicks so the scrim doesn't close
            about-content := VerticalLayout {
                padding: 24px;
                spacing: 6px;
                Text {
                    text: "IRON RENAMER";
                    color: Palette.text;
                    font-size: 15px;
                    font-weight: 800;
                    letter-spacing: 3px;
                }
                Text {
                    text: "version " + root.app_version;
                    color: Palette.amber;
                    font-size: 12px;
                    font-family: "Cascadia Mono";
                }
                Text {
                    text: "batch rename · live preview";
                    color: Palette.dim;
                    font-size: 11px;
                }
                Rectangle { height: 10px; }
                slint-link := TouchArea {
                    height: 16px;
                    mouse-cursor: pointer;
                    clicked => { root.open_url("https://slint.dev"); }
                    Text {
                        text: "Made with Slint — slint.dev";
                        color: slint-link.has-hover ? Palette.amber : Palette.dim;
                        font-size: 11px;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                        width: 100%;
                        height: 100%;
                        animate color { duration: 120ms; }
                    }
                }
                Rectangle { height: 14px; }
                Chip { label: "close"; clicked => { root.show_about = false; } }
            }
        }
    }

    // Frameless windows have no native resize borders; these strips start a
    // native resize drag. Maximized windows don't resize from the edges.
    if root.frameless && !root.maximized : Rectangle {
        EdgeGrip { dir: "n";  x: 12px; y: 0; width: parent.width - 24px; height: 4px; mouse-cursor: ns-resize; resize(d) => { root.win_resize(d); } }
        EdgeGrip { dir: "s";  x: 12px; y: parent.height - 4px; width: parent.width - 24px; height: 4px; mouse-cursor: ns-resize; resize(d) => { root.win_resize(d); } }
        EdgeGrip { dir: "w";  x: 0; y: 12px; width: 4px; height: parent.height - 24px; mouse-cursor: ew-resize; resize(d) => { root.win_resize(d); } }
        EdgeGrip { dir: "e";  x: parent.width - 4px; y: 12px; width: 4px; height: parent.height - 24px; mouse-cursor: ew-resize; resize(d) => { root.win_resize(d); } }
        EdgeGrip { dir: "nw"; x: 0; y: 0; width: 12px; height: 12px; mouse-cursor: nwse-resize; resize(d) => { root.win_resize(d); } }
        EdgeGrip { dir: "ne"; x: parent.width - 12px; y: 0; width: 12px; height: 12px; mouse-cursor: nesw-resize; resize(d) => { root.win_resize(d); } }
        EdgeGrip { dir: "sw"; x: 0; y: parent.height - 12px; width: 12px; height: 12px; mouse-cursor: nesw-resize; resize(d) => { root.win_resize(d); } }
        EdgeGrip { dir: "se"; x: parent.width - 12px; y: parent.height - 12px; width: 12px; height: 12px; mouse-cursor: nwse-resize; resize(d) => { root.win_resize(d); } }
    }
}
